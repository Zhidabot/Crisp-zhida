# HTTP server
PORT=8787

# Crisp plugin credentials
CRISP_TOKEN_IDENTIFIER=
CRISP_TOKEN_KEY=
CRISP_WEBHOOK_SIGNING_SECRET=

# Optional when this adapter handles only one Crisp website.
# If empty, website_id is learned from incoming Crisp webhooks and persisted in SESSION_STORE_PATH.
CRISP_WEBSITE_ID=

# ZHIDA Native gateway credentials from the channel integration page.
ZHIDA_GATEWAY_URL=https://your-zhida.example.com/v1/native/webhook
ZHIDA_ACCESS_KEY=
ZHIDA_SIGNING_SECRET=
ZHIDA_WEBHOOK_SECRET=

# Bot display on Crisp operator messages
BOT_NAME=AI Assistant
BOT_AVATAR=

# Adapter behavior
FORWARD_OPERATOR_MESSAGES=true
REQUEST_TIMEOUT_MS=15000
SESSION_STORE_PATH=./data/sessions.json
